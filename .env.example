# ThinkCam Configuration
# Copy this to .env and fill in your values

# Wyze Bridge / RTSP Stream
WYZE_RTSP_URL=rtsp://localhost:8554/stream/front_door
WYZE_MOCK=false

# Motion Detection
MOTION_SENSITIVITY=0.5          # 0.0 (most alerts) to 1.0 (least alerts)
MIN_MOTION_FRAMES=3             # Frames to buffer before triggering
DETECTION_MODE=auto             # auto, mediapipe_full, mediapipe_lite, framediff

# Recording
CLIPS_DIR=./clips
CLIP_DURATION=60                # Seconds per clip
CLIP_TRIGGER_THRESHOLD=0.6      # Confidence threshold (0.0-1.0)

# OneDrive
ONEDRIVE_ACCESS_TOKEN=           # Your OneDrive access token
ONEDRIVE_FOLDER_PATH=/wyze-clips
RETENTION_DAYS=7
ONEDRIVE_MOCK=true              # Set to true to test without real OneDrive

# Firebase
FIREBASE_CREDENTIALS_JSON=       # Path to Firebase credentials JSON
FIREBASE_MOCK=true              # Set to true to test without Firebase

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Authentication
JWT_SECRET=change-this-in-production

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/thinkcam.log
